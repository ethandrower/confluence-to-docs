# ---------------------------------------------------------------------------
# CiteMed Docs Portal — environment variables
#
# Local dev: copy this file to `.env` and fill in what you need. Defaults in
# citemed/settings.py are safe for local dev (SQLite, console email).
#
# Production (Dokku): set with `dokku config:set <app> KEY=value`. DO NOT
# commit a real `.env` — it's gitignored.
# ---------------------------------------------------------------------------

# --- Django core --------------------------------------------------------------
# Generate: python -c 'import secrets; print(secrets.token_urlsafe(64))'
SECRET_KEY=replace-me-with-a-long-random-string

# Production MUST be False.
DEBUG=True

# Comma-separated hostnames this app answers to.
ALLOWED_HOSTS=localhost,127.0.0.1

# Origins trusted for CSRF — must include scheme. Required when DEBUG=False
# and accepting POSTs from a public domain.
# CSRF_TRUSTED_ORIGINS=https://docs.example.com

# Django admin URL path. Default 'admin'. Override in production with
# something unguessable so the admin doesn't show up in bot scans of /admin/.
# ADMIN_PATH=internal-7f3a9b

# Public URL the frontend is served from. Used to build magic-link URLs in
# auth emails. Must be the exact origin users hit.
FRONTEND_URL=http://localhost:5174

# --- Database -----------------------------------------------------------------
# Dokku's Postgres plugin sets this automatically on `dokku postgres:link`.
# Local default is SQLite (db.sqlite3).
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Confluence ---------------------------------------------------------------
CONFLUENCE_DOMAIN=yourcompany.atlassian.net
CONFLUENCE_EMAIL=service-account@yourcompany.com
CONFLUENCE_API_TOKEN=your-api-token
CONFLUENCE_SPACE_KEY=CITEMED
# From https://yourcompany.atlassian.net/_edge/tenant_info
ATLASSIAN_CLOUD_ID=

# --- Email --------------------------------------------------------------------
# When MAILGUN_ACCESS_KEY is set, EMAIL_BACKEND auto-switches to
# django_mailgun.MailgunBackend. Otherwise default is the console backend
# (emails print to stdout — for local dev).
MAILGUN_ACCESS_KEY=
MAILGUN_SERVER_NAME=

# Visible "From" address on outgoing email.
DEFAULT_FROM_EMAIL=CiteMed Support <support@citemedical.com>

# Destination for contact-form submissions.
SUPPORT_EMAIL=support@citemed.com

# --- Portal -------------------------------------------------------------------
PORTAL_MAGIC_LINK_EXPIRY_MINUTES=15

# --- Optional: S3 for media uploads ------------------------------------------
# Leave AWS_STORAGE_BUCKET_NAME blank to use local filesystem.
AWS_STORAGE_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=us-east-1
# AWS_S3_ENDPOINT_URL=  # Set only for non-AWS S3 (R2, MinIO, etc.)
# MEDIA_URL=            # Set for R2/custom domain: https://assets.example.com/
