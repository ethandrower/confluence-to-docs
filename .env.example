DATABASE_URL=postgres://user:password@localhost:5432/citemed_portal
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

CONFLUENCE_DOMAIN=yourcompany.atlassian.net
CONFLUENCE_EMAIL=service-account@yourcompany.com
CONFLUENCE_API_TOKEN=your-api-token
CONFLUENCE_SPACE_KEY=CITEMED
ATLASSIAN_CLOUD_ID=your-cloud-id  # from https://yourcompany.atlassian.net/_edge/tenant_info

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=support@yourcompany.com
EMAIL_HOST_PASSWORD=your-email-password

FRONTEND_URL=http://localhost:5173
MEDIA_ROOT=/tmp/citemed-media

# S3 image storage (leave blank to use local MEDIA_ROOT in development)
# Supports AWS S3 and S3-compatible services (Cloudflare R2 etc.)
AWS_STORAGE_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=  # Set for R2: https://<account>.r2.cloudflarestorage.com
MEDIA_URL=            # Set for R2/custom domain: https://assets.yourcompany.com/
